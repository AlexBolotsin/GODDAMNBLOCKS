{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}\\build",
                "-G", "Visual Studio 17 2022",
                "-A", "x64"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Debug",
                "--parallel"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Release",
                "--parallel"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Build RelWithDebInfo",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "RelWithDebInfo",
                "--parallel"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Rebuild Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Debug",
                "--clean-first",
                "--parallel"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Rebuild Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Release",
                "--clean-first",
                "--parallel"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Clean Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Debug",
                "--target", "clean"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Clean Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Release",
                "--target", "clean"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Archive Release",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File", "${workspaceFolder}\\.vscode\\archive.ps1",
                "-WorkspaceFolder", "${workspaceFolder}"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": "Build Release",
            "problemMatcher": [],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        }
    ]
}
